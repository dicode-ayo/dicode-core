# The compiled `dicode` binary lives at the repo root. We don't want
# to commit it, but we DO want to commit `deploy/helm/dicode/` (the
# Helm chart directory whose name happens to collide).
/dicode
!deploy/helm/dicode/
node_modules/
.playwright-mcp/
.worktrees/
playwright-report/
test-results/
.playwright/
tests/e2e/.auth-state.json
# Top-level Deno lockfile — only tasks/deno.lock is authoritative.
/deno.lock
!.claude/memory/
